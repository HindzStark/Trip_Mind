# Antigravity / AI Assistant
# ------------------------------------------------------------

# Antigravity workspace and session data
.gemini/
.antigravity/

# Scratch directories (temporary AI-generated files)
scratch/

# AI assistant conversation artifacts (not project docs)
# Note: docs/ directory files ARE intentionally tracked

